# Dasha Bot (@asdasha_bot) — Дизайнер мебели, г. Абакан

# Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Owner Telegram ID
OWNER_ID=265070804

# Channel
CHANNEL_ID=1674792724
CHANNEL_USERNAME=@abakan_mebel

# Phone number (from website abakanmebel.online)
