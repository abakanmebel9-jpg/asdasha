# Даша работает на локальной модели с мульти-провайдерным фолбэком v5.0.

# ═══════════════════════════════════════════════════════════
# БАЗОВЫЕ НАСТРОЙКИ
# ═══════════════════════════════════════════════════════════

# Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Owner Telegram ID
OWNER_ID=265070804

# Channel
CHANNEL_ID=-1001674792724
CHANNEL_USERNAME=@abakan_mebel

# Phone number
PHONE=+7 (913) 448-37-17

# ═══════════════════════════════════════════════════════════
# AI PROVIDERS — Мульти-провайдерный фолбэк v5.0
# ═══════════════════════════════════════════════════════════
# Цепочка фолбэка:
#   Local → GitHub → HuggingFace → Groq → Gemini → OpenRouter → Cerebras → Pollinations
#
# Каждый провайдер: БЕСПЛАТНЫЙ, OpenAI-совместимый.
# Нужен только ключ (если указан). Pollinations — без ключа.
#
# ROUTE STRATEGY:
#   CHAT     → Local → GitHub → HuggingFace → Groq → Gemini → OpenRouter → Cerebras → Pollinations (auth)
#   COMMENT  → GitHub → HuggingFace → Groq → Gemini → OpenRouter → Cerebras → Pollinations (free only)
#   FUNCTION → Local → GitHub → HuggingFace → Groq → Gemini → OpenRouter → Cerebras → Pollinations (auth)
# ═══════════════════════════════════════════════════════════

# 1. GitHub Models (FREE via PAT)
#    Модели: GPT-4.1-mini (лучший русский!), Llama-3.3-70B
#    Как получить: github.com/settings/tokens → models:read scope
#    ВАЖНО: Fine-grained PAT требует "Models" permission (Account permissions → Read)
GH_PAT_TOKEN=your_github_pat_here
GH_REPO=abakanmebel9-jpg/asdasha

# 2. Groq (FREE, ОЧЕНЬ БЫСТРЫЙ — 0.5-2 сек!)
#    Модели: Llama-3.3-70B, Mixtral, Gemma
#    Как получить: console.groq.com → API Keys → Create Key
GROQ_API_KEY=your_groq_key_here

# 3. Google Gemini (FREE)
#    Модели: Gemini-2.0-Flash (отличный русский)
#    Как получить: aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_key_here

# 4. OpenRouter (FREE, 20+ моделей)
#    Модели: Llama-3.3-70B:free, Mistral-Small, Qwen-2.5-7B:free
#    Как получить: openrouter.ai → Keys → Create Key
OPENROUTER_API_KEY=your_openrouter_key_here

# 5. Cerebras (FREE, УЛЬТРА-БЫСТРЫЙ — 0.2-0.5 сек!)
#    Модели: Llama-3.3-70B
#    Как получить: cloud.cerebras.ai → API Keys
CEREBRAS_API_KEY=your_cerebras_key_here

# 6. Pollinations — ROUTE-AWARE (v6.0)
#    С API ключом: CHAT/FUNCTION маршруты используют auth API (19 моделей!)
#    Без ключа: все маршруты используют free anonymous tier
#    Протестированные модели (auth API, v6.0 — 19 рабочих):
#      ✅ NEW: gpt-5.4-mini, nova, nova-fast, minimax, minimax-m2.7,
#             perplexity-fast, step-3.5-flash, grok-large
#      ✅ ORIGINAL: openai, mistral, mistral-small-3.2, mistral-large,
#                   mistral-small, llama, llama-scout, grok, deepseek,
#                   qwen-coder, gemma
#      ❌ 402 (платные): gpt-5.4, glm, kimi, perplexity, grok-4-20-reasoning, qwen-large
#    Как получить ключ: enter.pollinations.ai
POLLINATIONS_API_KEY=sk_Zi7ULzl8uWy8yOjFubmhYeJvwAdltpOs
POLLINATIONS_BASE_URL=https://gen.pollinations.ai

# 7. HuggingFace Inference (FREE via HF_TOKEN — уже настроен для скачивания модели)
#    Модели: Qwen2.5-7B (отличный русский!), Llama-3.1-8B, Mistral-7B
#    Тот же HF_TOKEN, что и для скачивания модели — ничего дополнительно настраивать не нужно.
#    Провайдер автоматически включается в цепочку фолбэка если HF_TOKEN указан.

# HuggingFace — для скачивания модели И для бесплатного LLM inference
HF_TOKEN=your_huggingface_token

# ═══════════════════════════════════════════════════════════
# ЛОКАЛЬНАЯ МОДЕЛЬ — PRIMARY
# ═══════════════════════════════════════════════════════════

ENABLE_LOCAL_MODEL=true
MODEL_PATH=models/RuadaptQwen3-4B-Instruct-Q4_K_M.gguf
MODEL_N_CTX=8192
MODEL_N_THREADS=3
MODEL_MAX_TOKENS=2048

# Model auto-download
MODEL_AUTO_DOWNLOAD=true
MODEL_DOWNLOAD_URL=https://huggingface.co/RefalMachine/RuadaptQwen3-4B-Instruct-GGUF/resolve/main/Q4_K_M.gguf
MODEL_HISTORY_LIMIT=6

# ═══════════════════════════════════════════════════════════
# БАЗА ДАННЫХ И РАСПИСАНИЕ
# ═══════════════════════════════════════════════════════════

DB_PATH=data/dasha_bot.db

NEWS_INTERVAL_MINUTES=30
CHANNEL_POST_INTERVAL_MINUTES=30
HOURLY_POST_LIMIT=2
DAILY_POST_LIMIT=48

# ═══════════════════════════════════════════════════════════
# ПОВЕДЕНИЕ В ГРУППАХ — Даша отвечает на ВСЕ события
# ═══════════════════════════════════════════════════════════
# Отвечать на КАЖДОЕ сообщение во ВСЕХ чатах и группах (бесплатная реклама)
GROUP_RESPOND_ALL=true
# Per-chat cooldown (сек) для НЕприоритетных сообщений (упоминания/replies/мебель обходят)
GROUP_COOLDOWN_SECONDS=8
# Доля реакций-эмодзи на сообщения в группах (0.0-1.0)
GROUP_REACTION_PROBABILITY=0.35
# Игнорировать сообщения от других ботов (предотвращает циклы)
GROUP_IGNORE_BOTS=true

# ═══════════════════════════════════════════════════════════
# ПРОЧЕЕ
# ═══════════════════════════════════════════════════════════

LOCK_FILE=/tmp/dasha_bot.lock
LOG_LEVEL=INFO
