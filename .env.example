# Dasha Bot (@asdasha_bot) — Дизайнер мебели, г. Абакан
# Даша работает ТОЛЬКО на локальной модели RuadaptQwen3-4B-Instruct Q4_K_M.

# Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Owner Telegram ID
OWNER_ID=265070804

# Channel
CHANNEL_ID=-1001674792724
CHANNEL_USERNAME=@abakan_mebel

# Phone number (получен с сайта abakanmebel.online)
PHONE=+7 (913) 448-37-17

# Pollinations AI — аварийный fallback (используется ТОЛЬКО если локальная модель недоступна)
POLLINATIONS_API_KEY=your_pollinations_api_key_here
POLLINATIONS_BASE_URL=https://gen.pollinations.ai

# HuggingFace — for model download
HF_TOKEN=your_huggingface_token

# GitHub PAT (for self-dispatch in Actions)
GH_PAT_TOKEN=your_github_pat_here
GH_REPO=abakanmebel9-jpg/asdasha

# Local model settings — RuadaptQwen3-4B-Instruct Q4_K_M (PRIMARY, ONLY)
ENABLE_LOCAL_MODEL=true
MODEL_PATH=models/RuadaptQwen3-4B-Instruct-Q4_K_M.gguf
MODEL_N_CTX=8192
MODEL_N_THREADS=3
MODEL_MAX_TOKENS=2048

# Model auto-download
MODEL_AUTO_DOWNLOAD=true
MODEL_DOWNLOAD_URL=https://huggingface.co/RefalMachine/RuadaptQwen3-4B-Instruct-GGUF/resolve/main/Q4_K_M.gguf
MODEL_HISTORY_LIMIT=6

# Database
DB_PATH=data/dasha_bot.db

# Schedule settings — 2 posts per hour (interval 30 min)
NEWS_INTERVAL_MINUTES=30
CHANNEL_POST_INTERVAL_MINUTES=30
HOURLY_POST_LIMIT=2
DAILY_POST_LIMIT=48

# Log level
LOG_LEVEL=INFO